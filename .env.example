# Environment
NODE_ENV=development

# Database
DATABASE_URL=postgres://kunci:kunci_dev@localhost:12501/kunci_dev

# Cache
REDIS_URL=redis://127.0.0.1:27096

# OpenRouter (LLM)
OPENROUTER_API_KEY=your-openrouter-api-key
# Max concurrent OpenRouter requests (default: 3)
OPENROUTER_MAX_CONCURRENCY=3

# Resend (Email)
RESEND_API_KEY=re_your-resend-api-key
# Required in production — get from Resend dashboard → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=
SENDER_EMAIL=ai-sdr@yourdomain.com
SENDER_NAME=KUNCI AI SDR

# Deepcrawl (Web Scraping)
DEEPCRAWL_API_KEY=dc-your-deepcrawl-api-key
# LinkedIn crawling is disabled unless you have explicit LinkedIn crawl permission.
LINKEDIN_CRAWLING_PERMISSION_CONFIRMED=false

# Auth
BETTER_AUTH_SECRET=change-me-generate-a-random-secret
ADMIN_USER=admin
ADMIN_PASS=change-me

# Server
PORT=3005
WEB_ORIGIN=http://localhost:5418
# Public origin used in outbound unsubscribe links. Defaults to http://localhost:$PORT.
PUBLIC_API_URL=

# Unsubscribe / opt-out
# HMAC secret for one-click unsubscribe tokens. Falls back to BETTER_AUTH_SECRET when unset.
UNSUBSCRIBE_SECRET=

# Branding (used in email footer "sent by X" line)
SENDER_COMPANY=KUNCI.AI

# Pipeline queue (BullMQ on Redis)
PIPELINE_WORKER_CONCURRENCY=3
PIPELINE_RATE_MAX=10
PIPELINE_RATE_DURATION_MS=1000
PIPELINE_AUTO_ENQUEUE=true

# IMAP inbound polling (alternative to Resend Inbound webhook)
# Enables a background poller that fetches unseen messages and routes them
# through handleReply. Useful when sender domain MX cannot point to Resend.
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_BATCH_SIZE=25
IMAP_POLL_INTERVAL_SECONDS=60

# Optional: Slack incoming-webhook URL for notifications (leave blank to disable)
SLACK_WEBHOOK_URL=
