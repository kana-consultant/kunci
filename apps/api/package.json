{
	"name": "@kunci/api",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"scripts": {
		"dev": "tsx watch --env-file=../../.env src/main.ts",
		"build": "tsup src/main.ts src/index.ts --format esm --dts",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx src/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/infrastructure/db/seed.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.8",
		"@hono/zod-validator": "^0.5.0",
		"@orpc/client": "^1.4.0",
		"@orpc/server": "^1.4.0",
		"croner": "^9.0.0",
		"deepcrawl": "^0.1.0",
		"drizzle-orm": "^0.39.0",
		"hono": "^4.7.0",
		"ioredis": "^5.4.0",
		"pino": "^9.6.0",
		"postgres": "^3.4.0",
		"resend": "^4.1.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"drizzle-kit": "^0.30.0",
		"pino-pretty": "^13.1.3",
		"tsup": "^8.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.4.0"
	}
}
