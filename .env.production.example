# KUNCI Production Environment
# Copy this file to .env.production and fill in all values.
# NEVER commit .env.production to git.

# ── Required ────────────────────────────────────────────────────────────────

NODE_ENV=production

# PostgreSQL (used by docker-compose.prod.yml)
DATABASE_URL=postgres://kunci:CHANGE_ME@localhost:5432/kunci_prod
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# Cache
REDIS_URL=redis://127.0.0.1:6379

# OpenRouter (LLM API)
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
# Max concurrent OpenRouter requests (default: 3)
OPENROUTER_MAX_CONCURRENCY=3

# Resend (Email delivery)
RESEND_API_KEY=re_your-resend-api-key
# Required in production — forged webhooks bypass auth otherwise
RESEND_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
SENDER_EMAIL=sdr@yourdomain.com
SENDER_NAME=KUNCI AI SDR

# Deepcrawl (Web scraping)
DEEPCRAWL_API_KEY=dc-your-deepcrawl-api-key
# Keep false unless LinkedIn has explicitly approved your crawl scope.
LINKEDIN_CRAWLING_PERMISSION_CONFIRMED=false

# ── Auth ────────────────────────────────────────────────────────────────────

BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_SECRET
BETTER_AUTH_URL=https://yourdomain.com

# API key for programmatic access to protected endpoints
API_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# Dashboard login credentials (Basic Auth)
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_USE_A_STRONG_PASSWORD

# ── Server ──────────────────────────────────────────────────────────────────

PORT=3001
WEB_ORIGIN=https://yourdomain.com
# Path to built web app (served by Hono in production)
WEB_DIST_PATH=../web/dist

# ── Optional ─────────────────────────────────────────────────────────────────

# Slack incoming-webhook URL — enables notifications on invalid emails & pipeline failures
SLACK_WEBHOOK_URL=
